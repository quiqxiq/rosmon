# Roskit backend host (no trailing slash, no /api/v1 — client appends it).
# In docker-compose dev, the backend is exposed on 8080.
VITE_API_URL=http://localhost:8080

# Optional: Clerk auth key (legacy from shadcn-admin template). Roskit uses
# its own JWT auth via /auth/login, so this is unused. Kept for now to avoid
# breaking the template's @clerk/react import surface.
VITE_CLERK_PUBLISHABLE_KEY=