# Simulasi Jaringan MikroTik — Linux / Fedora
# Salin ke .env lalu sesuaikan nilainya.
#
# Cek nama bridge yang aktif:
#   virsh net-list --all
#   ip link show type bridge

# ─── Libvirt bridge interfaces ────────────────────────────────────────────────
HOTSPOT_BRIDGE=virbr-hs
PPPOE_BRIDGE=virbr-pppoe

# ─── Hotspot network ──────────────────────────────────────────────────────────
HOTSPOT_SUBNET=192.168.123.0/24
HOTSPOT_GW=192.168.123.1
HOTSPOT_RANGE=192.168.123.192/26
HOTSPOT_CLIENT_IP=192.168.123.200

# ─── PPPoE network ────────────────────────────────────────────────────────────
PPPOE_SUBNET=192.168.111.0/24
PPPOE_GW=192.168.111.1
PPPOE_RANGE=192.168.111.192/26
PPPOE_CLIENT_IP=192.168.111.200

# ─── PPPoE credentials ────────────────────────────────────────────────────────
PPPOE_USER=test
PPPOE_PASS=1122

# ─── Firefox port (akses dari browser host) ───────────────────────────────────
FIREFOX_PORT=5800
