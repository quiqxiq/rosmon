# rosmon environment

# === Database (PostgreSQL) ===
# Sesuaikan dengan service postgres di docker-compose.yml
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mikhmon
DB_USER=mikhmon
DB_PASSWORD=secret
DB_SSLMODE=disable

# === InfluxDB3 (historical data) ===
# Jalankan: docker compose up -d influxdb3
INFLUX_ENABLED=false
INFLUX_HOST=http://localhost:8181
INFLUX_TOKEN=87675181929e949adf13285ba6dfa4a63cbd8b03f0c54d02982a3334127d4d20
INFLUX_DATABASE=mikhmon

# === HTTP server ===
HTTP_BIND=0.0.0.0:8080
HTTP_READ_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_GRACE=10s
# Production: lock ke origin tertentu, mis. "https://dashboard.example.com"
CORS_ALLOWED_ORIGINS=*

# === Integration test ===
# Prefix untuk resource yang dibuat saat test (mudah cleanup manual).
MIKHMON_IT_PREFIX=mikhmon-it
JWT_SECRET=16a970954b409cee51b15928e3ce18b596251c3803cf99be5204857762644273
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
BCRYPT_COST=12
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# === On-Login Webhook (selling record) ===
# IP/port Go service yang reachable dari MikroTik router (bukan dari browser).
# Ganti dengan IP LAN server tempat rosmon berjalan.
# Contoh: GO_SERVICE_URL=http://192.168.1.10:8080
# Setelah di-set + restart, jalankan Sync di tab Profiles agar script
# on-login di router di-inject ulang dengan blok /tool/fetch.
GO_SERVICE_URL=http://192.168.233.254:8080
