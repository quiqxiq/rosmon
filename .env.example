# rosmon environment template

# ==============================================================================
# ℹ️ PANDUAN DOCKER & SETUP (TERBARU)
# ==============================================================================
# 1. Jalankan 'make setup' untuk meng-copy file ini ke .env dan mengisi JWT_SECRET
#    serta DEVICE_PASSWORD_KEY secara otomatis dengan nilai acak yang aman.
#
# 2. Dua Mode Docker Compose Full Stack:
#    a. Development (Vite HMR frontend + Go API backend):
#       - Jalankan: 'make up-dev'
#       - Frontend: http://localhost:5173
#       - API Server: http://localhost:8080
#    b. Production (Frontend disajikan via Nginx + Go API backend):
#       - Jalankan: 'make up'
#       - Frontend: http://localhost (Port 80)
#       - API Server: http://localhost:8080
#
# 3. Pengaturan InfluxDB 3:
#    - Jalankan: 'make influx-token' setelah container up untuk meng-generate
#      token admin secara otomatis dan menyimpannya ke INFLUX_TOKEN di bawah ini.
# ==============================================================================

# === Database (PostgreSQL) ===
# Jika berjalan di luar Docker (host lokal), gunakan DB_HOST=localhost.
# Jika berjalan di dalam Docker, gunakan DB_HOST=postgres (nama service).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mikhmon
DB_USER=mikhmon
DB_PASSWORD=secret
DB_SSLMODE=disable

# === InfluxDB3 (historical data) ===
# Server berjalan mode --without-auth saat pertama kali start.
# Jalankan 'make influx-token' untuk menyetel INFLUX_ENABLED=true dan
# menulis token admin valid yang digenerate oleh container InfluxDB ke sini.
INFLUX_ENABLED=false
INFLUX_HOST=http://localhost:8181
INFLUX_TOKEN=
INFLUX_DATABASE=mikhmon

# === HTTP server ===
HTTP_BIND=127.0.0.1:8080
HTTP_READ_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_GRACE=10s
# CORS origins, comma-separated. Wajib di-set untuk browser frontend.
# Set "*" hanya untuk development lokal (BERBAHAYA di production).
# Kosong = tolak semua cross-origin request (same-origin only).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# === Authentication ===
# JWT secret minimal 32 karakter. Otomatis terisi acak saat menjalankan 'make setup'.
JWT_SECRET=replace-with-32-char-or-longer-secret-string-here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
BCRYPT_COST=12
# Admin bootstrap — dibuat saat startup kalau belum ada user di DB.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-login

# === Rate Limiting & SSE Cap ===
RATE_LIMIT_USER_RPM=60
RATE_LIMIT_IP_RPM=20
RATE_LIMIT_HEAVY_RPM=10
SSE_MAX_PER_TOPIC=20
SSE_MAX_PER_DEVICE=50

# === Device Password Encryption ===
# AES-256-GCM key untuk enkripsi password router di database.
# Otomatis terisi acak saat menjalankan 'make setup'.
DEVICE_PASSWORD_KEY=

# === Device TLS ===
# Set true untuk skip verifikasi sertifikat TLS ( self-signed cert).
# DEVICE_TLS_INSECURE=false

# === On-Login Webhook (selling record) ===
# URL absolut Go service yang reachable dari MikroTik router.
GO_SERVICE_URL=

# Shared secret untuk webhook dari MikroTik router.
# Jika di-set, router harus mengirim header "X-Rosmon-Secret: <nilai>" di setiap
# request ke /hook/hotspot/login/:device_id.
# Kosong = tidak ada validasi (cocok untuk development lokal, BERBAHAYA di production).
# Generate: openssl rand -hex 32
HOOK_SHARED_SECRET=

# === Integration test ===
MIKHMON_IT_PREFIX=mikhmon-it

# === Payment Gateway — Xendit ===
# Konfigurasi Xendit (secret key, webhook token, durasi, APP_URL) TIDAK lagi
# diset via env var. Semua konfigurasi dikelola melalui UI:
#
#   Settings → Payment Gateway
#
# Setelah login sebagai admin, buka halaman tersebut untuk:
#   1. Mengisi Xendit API Secret Key
#   2. Mengisi X-CALLBACK-TOKEN dari Xendit Dashboard → Webhooks
#   3. Mengatur URL redirect dan durasi link pembayaran
#   4. Klik "Test Koneksi" untuk verifikasi
#
# URL webhook yang harus didaftarkan di Xendit Dashboard:
#   <APP_URL>/api/v1/public/webhooks/xendit
