# rosmon environment

# === Database (PostgreSQL) ===
# Sesuaikan dengan service postgres di docker-compose.yml
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mikhmon
DB_USER=mikhmon
DB_PASSWORD=secret
DB_SSLMODE=disable

# === InfluxDB3 (historical data) ===
# Jalankan: docker compose up -d influxdb3
# Buat token: docker exec mikhmon-influx influxdb3 create token --admin
INFLUX_ENABLED=true
INFLUX_HOST=http://localhost:8181
INFLUX_TOKEN=<your-influxdb3-admin-token>
INFLUX_DATABASE=mikhmon

# === HTTP server ===
HTTP_BIND=127.0.0.1:8080
HTTP_READ_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_GRACE=10s
# CORS origins, comma-separated. Wajib di-set untuk browser frontend.
# Contoh: "http://localhost:5173,https://dashboard.example.com".
# Set "*" hanya untuk development lokal (BERBAHAYA di production).
# Kosong = tolak semua cross-origin request (same-origin only).
CORS_ALLOWED_ORIGINS=

# === Authentication (Phase 2) ===
# WAJIB: JWT secret minimal 32 karakter. Generate: openssl rand -hex 32
JWT_SECRET=replace-with-32-char-or-longer-secret-string-here
# Access token TTL (default 15m). Refresh TTL (default 168h = 7d).
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
# Bcrypt cost. 12 = production (~250ms). 4 = test (~1ms). Range 4-31.
BCRYPT_COST=12
# Admin bootstrap — dibuat saat startup kalau belum ada user di DB.
# Kosongkan kalau user sudah ada / mau buat manual.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-on-first-login

# === Rate Limiting & SSE Cap (Phase 4) ===
# Per JWT user, request/menit (default 60).
RATE_LIMIT_USER_RPM=60
# Per IP untuk endpoint anon (login, healthz). Default 20.
RATE_LIMIT_IP_RPM=20
# Per (user, endpoint) untuk heavy endpoint (voucher generate, bulk delete,
# reboot, shutdown). Default 10.
RATE_LIMIT_HEAVY_RPM=10
# Maximum SSE subscriber per topic (default 20).
SSE_MAX_PER_TOPIC=20
# Maximum SSE subscriber per device (cross-topic, default 50).
SSE_MAX_PER_DEVICE=50

# === Device Password Encryption ===
# AES-256-GCM key untuk enkripsi password router di database.
# WAJIB di-set di production — tanpa ini password disimpan plaintext.
# Generate: openssl rand -hex 32
# CATATAN: Jika di-set setelah device sudah dibuat, password lama (plaintext)
# akan otomatis di-pass-through sampai next Update (migrasi gradual).
DEVICE_PASSWORD_KEY=

# === Device TLS ===
# Set true untuk skip verifikasi sertifikat TLS (berguna kalau router pakai
# self-signed cert). BERBAHAYA di production — hanya untuk dev/testing.
# DEVICE_TLS_INSECURE=false

# === On-Login Webhook (selling record) ===
# URL absolut Go service yang reachable dari MikroTik router (bukan dari
# browser/operator). Dipakai oleh on-login script untuk mencatat selling
# record ke PostgreSQL saat user login pertama kali.
#
# Format: http://<host>:<port>  (tanpa trailing slash, tanpa path)
# Contoh: GO_SERVICE_URL=http://192.168.1.10:8080
#
# Webhook endpoint final: <GO_SERVICE_URL>/api/v1/hook/hotspot/login/<device_id>
#
# Kalau kosong, blok webhook di on-login script tidak di-emit dan selling
# record tidak akan di-record otomatis (operator tetap bisa generate report
# berdasarkan data expiry service).
#
# PERINGATAN MVP: endpoint webhook ini TIDAK pakai authentication.
# Jangan expose port ke internet publik. Pakai firewall rule supaya hanya
# reachable dari MikroTik router.
GO_SERVICE_URL=

# === Integration test ===
# Prefix untuk resource yang dibuat saat test (mudah cleanup manual).
MIKHMON_IT_PREFIX=mikhmon-it
